<launch>
  <include file="$(find me5413_world)/launch/world.launch" />
  <include file="$(find me5413_world)/launch/navigation.launch" />

  <node pkg="me5413_world"
        type="task2_controller.py"
        name="task2_controller"
        output="screen">
    <rosparam command="load" file="$(find me5413_world)/config/task2_waypoints.yaml" />
  </node>
</launch>