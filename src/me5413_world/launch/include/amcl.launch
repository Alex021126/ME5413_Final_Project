<launch>
  <!-- ========================= -->
  <!-- Arguments with Defaults -->
  <!-- ========================= -->
  <arg name="use_map_topic" default="false"/>
  <arg name="scan_topic" default="/front/scan"/>

  <!-- ========================= -->
  <!-- Optimized AMCL Node -->
  <!-- ========================= -->
  <node pkg="amcl" type="amcl" name="amcl" output="screen">

    <!-- Map topic usage -->
    <param name="use_map_topic" value="$(arg use_map_topic)"/>

    <!-- Coordinate Frames -->
    <param name="odom_frame_id" value="odom"/>
    <param name="base_frame_id" value="base_link"/>
    <param name="global_frame_id" value="map"/>

    <!-- Laser Configuration -->
    <param name="laser_model_type" value="likelihood_field"/>
    <param name="laser_max_beams" value="30"/>          <!-- Reduced for performance -->
    <param name="laser_z_hit" value="0.85"/>           <!-- Slightly higher confidence -->
    <param name="laser_z_rand" value="0.15"/>          <!-- Less random noise -->
    <param name="laser_sigma_hit" value="0.07"/>       <!-- Tighter Gaussian model -->
    <param name="laser_likelihood_max_dist" value="1.5"/> <!-- Ignore far noise -->

    <!-- Motion Model (Reduced Noise) -->
    <param name="odom_alpha1" value="0.05"/>
    <param name="odom_alpha2" value="0.05"/>
    <param name="odom_alpha3" value="0.025"/>
    <param name="odom_alpha4" value="0.025"/>

    <!-- Particle Filter Settings -->
    <param name="min_particles" value="100"/>         <!-- Reduced for real-time -->
    <param name="max_particles" value="500"/>

    <!-- Update Thresholds -->
    <param name="update_min_d" value="0.15"/>        <!-- Smaller updates for smoother tracking -->
    <param name="update_min_a" value="0.15"/>

    <!-- TF Parameters -->
    <param name="transform_tolerance" value="0.3"/>   <!-- Faster recovery if TF delays -->

    <!-- Disable Random Jumping -->
    <param name="recovery_alpha_slow" value="0.0"/>
    <param name="recovery_alpha_fast" value="0.0"/>

    <!-- Map Handling -->
    <param name="receive_map_topic" value="true"/>
    <param name="first_map_only" value="true"/>

    <!-- Scan Topic Remap -->
    <remap from="scan" to="$(arg scan_topic)"/>

  </node>
</launch>
