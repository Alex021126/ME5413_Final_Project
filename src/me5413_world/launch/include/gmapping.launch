<launch>
  <arg name="scan_topic" default="/front/scan" />

  <node pkg="gmapping" type="slam_gmapping" name="slam_gmapping" output="screen">
    <param name="odom_frame" value="odom" />
    <param name="base_frame" value="base_link" />
    <param name="map_frame" value="map" />

    <!-- Use every scan and update the map more frequently for tighter alignment. -->
    <param name="throttle_scans" value="1" />
    <param name="map_update_interval" value="1.0" />

    <!-- Keep the usable scan range conservative to reduce noisy far returns indoors. -->
    <param name="maxUrange" value="8.0" />
    <param name="maxRange" value="10.0" />

    <param name="sigma" value="0.05" />
    <param name="kernelSize" value="1" />
    <param name="lstep" value="0.03" />
    <param name="astep" value="0.03" />
    <param name="iterations" value="8" />
    <param name="lsigma" value="0.075" />
    <param name="ogain" value="3.0" />
    <param name="minimumScore" value="50.0" />
    <param name="lskip" value="0" />

    <!-- Motion noise tuned higher than the Jackal defaults to better absorb wheel slip on ramps. -->
    <param name="srr" value="0.02" />
    <param name="srt" value="0.04" />
    <param name="str" value="0.02" />
    <param name="stt" value="0.04" />

    <param name="linearUpdate" value="0.05" />
    <param name="angularUpdate" value="0.025" />
    <param name="temporalUpdate" value="0.5" />
    <param name="resampleThreshold" value="0.5" />
    <param name="particles" value="40" />

    <!-- Start with bounds large enough for the full project world to reduce reallocation churn. -->
    <param name="xmin" value="-35.0" />
    <param name="ymin" value="-25.0" />
    <param name="xmax" value="35.0" />
    <param name="ymax" value="25.0" />
    <param name="delta" value="0.03" />

    <param name="llsamplerange" value="0.01" />
    <param name="llsamplestep" value="0.01" />
    <param name="lasamplerange" value="0.005" />
    <param name="lasamplestep" value="0.005" />

    <remap from="scan" to="$(arg scan_topic)" />
  </node>
</launch>
